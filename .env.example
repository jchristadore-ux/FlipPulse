# ─────────────────────────────────────────────────────────────────────────────
# FlipPulse — per-customer environment variables
#
# Copy these into the Railway service's Variables tab for THIS customer.
# Do NOT commit real values. One Kalshi key + one Telegram bot per customer.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kalshi API (this customer's own key) ─────────────────────────────────────
KALSHI_API_KEY_ID=
# TWO ways to give the bot the private key — use ONE:
#
#   RECOMMENDED (foolproof) — KALSHI_PRIVATE_KEY_PEM_B64:
#     the whole PEM base64-encoded into ONE line. A single line of base64 can't be
#     mangled by the newline/space/quote problems that silently truncate a pasted
#     multi-line PEM. The onboarding /admin deploy view and `admin_cli.py` output
#     this value ready to paste. To make it by hand from a key file:
#       base64 -w0 my_key.pem       # Linux
#       base64 -i my_key.pem        # macOS
KALSHI_PRIVATE_KEY_PEM_B64=
#
#   LEGACY — KALSHI_PRIVATE_KEY_PEM: the raw multi-line PEM (BEGIN/END included).
#     Still works, but multi-line pastes are error-prone — prefer the B64 var above.
KALSHI_PRIVATE_KEY_PEM=

# ── Mode ─────────────────────────────────────────────────────────────────────
# true  = paper trading (DEMO). This is the default and how every customer
#         starts. Going live is a deliberate later step — either flip this var and
#         redeploy, or self-serve from the dashboard / Telegram `/live confirm`,
#         which writes MODE_OVERRIDE_PATH below and restarts the bot into live mode.
# false = live trading against real funds.
DEMO_MODE=true
# Starting paper balance (USD) used when DEMO_MODE=true (default 1000). Human
# formatting like $1,000 is tolerated.
PAPER_BALANCE=1000
# Seconds between main-loop scans (default 30). Lower = faster reactions and
# more API calls; leave it unless you know why you're changing it.
# POLL_INTERVAL_SECS=30

# ── Strategy ─────────────────────────────────────────────────────────────────
# Which trading format (risk mode) the bot runs. One of:
#   conservative | balanced | aggressive
# The format seeds this customer's percentage sizing + entry gates. Run
# `python formats.py` to print the full breakdown. Balanced is the default.
TRADING_FORMAT=

# ── Position sizing (PERCENTAGES of the current balance) ──────────────────────
# ALL sizing is a fraction of the live/paper balance, so it scales to ANY
# starting balance and compounds as the account grows (0.10 = 10%). Leaving
# these blank uses the values seeded by TRADING_FORMAT above; set them to
# override the format for this specific customer.
#   NORMAL_TRADE_PCT    full stake fraction        (balanced default 0.10)
#   RECOVERY_TRADE_PCT  reduced stake while clawing back a loss (0.03)
#   MAX_TRADE_PCT       hard ceiling on any single trade        (0.15)
NORMAL_TRADE_PCT=
RECOVERY_TRADE_PCT=
MAX_TRADE_PCT=
# The customer can retune NORMAL_TRADE_PCT at runtime by messaging their bot
# "/risk <percent>" (e.g. /risk 8); "/risk reset" restores the value above.
# RISK_MIN_TRADE_PCT is the hard floor a /risk request is clamped to (the ceiling
# is always MAX_TRADE_PCT). Leave blank for the 0.01 (1%) default.
RISK_MIN_TRADE_PCT=
# Recovery Mode "No Stake Change": when ON, recovery still triggers and tracks the
# claw-back to the pre-loss balance, but it does NOT drop the stake to
# RECOVERY_TRADE_PCT — the stake stays at the full NORMAL_TRADE_PCT (or the /risk
# value) and laddering keeps working, and there is no post-recovery ramp on exit.
# This is the boot default; the customer can flip it live from Telegram with
# "/recoverynostakechange on|off" (writes RECOVERY_NSC_OVERRIDE_PATH, which wins).
# RECOVERY_NO_STAKE_CHANGE=false
RECOVERY_NSC_OVERRIDE_PATH=/data/recovery_nsc_override.json
# Recovery win-rate restore: while recovery holds the stake BELOW the base (the
# standard reduced tier, or the ladder demoting it), a strong recovery-scoped win
# rate returns straight to the full stake + laddering, skipping the probation ramp.
# Fires at >= RECOVERY_WINRATE_RESTORE_PCT over >= RECOVERY_WINRATE_MIN_TRADES
# settled recovery trades. Set the % to 1.0 or ENABLED=false to turn it off.
# RECOVERY_WINRATE_RESTORE_ENABLED=true
# RECOVERY_WINRATE_RESTORE_PCT=0.70
# RECOVERY_WINRATE_MIN_TRADES=5

# ── Telegram (this customer's own bot from BotFather) ────────────────────────
TELEGRAM_BOT_TOKEN=
# The customer's chat id. The bot sends alerts here and answers /status and
# /health-log from here.
TELEGRAM_CHAT_ID=
# Optional: your own (operator) chat id so every alert also fans out to you,
# without a shared group. Comma-separated for multiple operators. Leaving this
# blank keeps alerts customer-only. See "Operator oversight" in CUSTOMER_ONBOARDING.md.
TELEGRAM_OPERATOR_CHAT_ID=
# Resilience knobs (optional — sane defaults, leave blank unless tuning). If
# Telegram is unreachable at boot (a slow deploy network is the usual cause),
# the bot keeps trading and retries the connection in the background, turning
# alerts on automatically once connectivity returns — no redeploy needed.
# TELEGRAM_SELFHEAL_INTERVAL=15       # seconds between background retries
# TELEGRAM_SELFHEAL_MAX_MINUTES=60    # give up self-healing after this long
# Minimal-alerts mode (default ON): the bot sends ONLY trade-entry, trade-settle,
# the twice-daily 9am/9pm summary, and hard safety alerts (HALT, volatility
# circuit breaker, boot failure). All other lifecycle chatter — boot summary,
# recovery/probation mode-change notices, monthly billing, mode-flip restart,
# shutdown — is suppressed (still logged and on /status). Set to false to restore
# the old, chattier behavior.
# TELEGRAM_MINIMAL_ALERTS=true

# ── Scheduled report (twice-daily P&L + win-rate briefing) ───────────────────
# A concise briefing the bot sends at fixed local times: balance, today's P&L,
# today's win rate, and the all-time (this-run) figures. On by default at 9am and
# 9pm US Eastern. All optional — leave blank for the defaults.
# REPORT_SCHEDULE_ENABLED=true          # set false to turn the briefing off
# REPORT_TIMEZONE=America/New_York      # any IANA tz; the report hours are in it
# REPORT_HOURS=9,21                     # comma-separated hours (0–23) to fire at
# REPORT_MAX_LATE_SECS=7200             # skip a slot missed (down) longer than this
REPORT_STATE_PATH=/data/report_state.json

# ── State file paths ─────────────────────────────────────────────────────────
# These are pointed at the attached Railway volume at /data so state survives
# redeploys — that's exactly why they're pre-filled here. Keep them on /data.
# NOTE: the code's built-in fallback (if a var is left unset) is a container-
# local relative file, which is WIPED on every redeploy — so do not clear these
# unless you mount the volume somewhere other than /data, in which case repoint
# them all at that mount.
RECOVERY_STATE_PATH=/data/recovery_state.json
PROBATION_STATE_PATH=/data/probation_state.json
LADDER_STATE_PATH=/data/ladder_state.json
BUCKET_STATS_PATH=/data/bucket_stats.json
BILLING_STATE_PATH=/data/billing_state.json
# Persistent all-time W/L + PnL tally (paper/live), so the all-time win rate the
# customer sees never resets on a redeploy. Keep on /data to survive redeploys.
LIFETIME_STATS_PATH=/data/lifetime_stats.json
# Status snapshot the bot rewrites each cycle; /status reads this file.
STATUS_SNAPSHOT_PATH=/data/status_snapshot.json
# Rolling health/activity log; /health-log tails this file.
HEALTH_LOG_PATH=/data/health.log
# Customer risk override the /risk command writes and the engine reads back.
RISK_OVERRIDE_PATH=/data/risk_override.json

# ── Self-service customer dashboard (dashboard.py) ────────────────────────────
# A login-protected web page the bot serves so the customer can tune their own
# setup (risk %, trading format, Telegram alerts, set-aside reserve) with no
# redeploy. DISABLED unless DASHBOARD_PASSWORD is set — then the bot serves it on
# $DASHBOARD_PORT (falls back to $PORT, then 8080). Generate a domain for the bot
# service in Railway to expose it; serve only over HTTPS (it takes a password).
DASHBOARD_PASSWORD=
# Optional: port to bind (default $PORT then 8080) and where the session-signing
# secret is persisted so logins survive redeploys.
# DASHBOARD_PORT=
DASHBOARD_SECRET_PATH=/data/dashboard_secret
# Override files the dashboard writes and the engine / telegram layer read back.
RESERVE_OVERRIDE_PATH=/data/reserve_override.json
FORMAT_OVERRIDE_PATH=/data/format_override.json
TELEGRAM_PREFS_PATH=/data/telegram_prefs.json
# Paper↔live flip: the dashboard / Telegram /live|/paper write the desired mode
# here; the bot restarts into it once flat. Overrides the DEMO_MODE env above.
MODE_OVERRIDE_PATH=/data/mode_override.json

# ── Performance-fee billing (high-water mark) — PLACEHOLDER, DISABLED ─────────
# The performance fee is TEMPORARILY REMOVED and not currently charged, so this
# is 0 (the monthly report stays off). To re-enable later, set PERF_FEE_PCT to
# e.g. 0.20 — the bot will then report (never charge) that % of each customer's
# NEW monthly profit above their all-time high-water mark, for you to invoice.
PERF_FEE_PCT=0.0
# Append-only JSON-lines log of each month's billable profit + fee (for invoicing).
BILLING_LOG_PATH=/data/billing.log
