# ─────────────────────────────────────────────────────────────────────────────
# FlipPulse — per-customer environment variables
#
# Copy these into the Railway service's Variables tab for THIS customer.
# Do NOT commit real values. One Kalshi key + one Telegram bot per customer.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kalshi API (this customer's own key) ─────────────────────────────────────
KALSHI_API_KEY_ID=
# Paste the full PEM including the BEGIN/END lines. In Railway, paste it as a
# single multi-line variable value.
KALSHI_PRIVATE_KEY_PEM=

# ── Mode ─────────────────────────────────────────────────────────────────────
# true  = paper trading (DEMO). This is the default and how every customer
#         starts. Going live is a deliberate later step.
# false = live trading against real funds.
DEMO_MODE=true
# Starting paper balance (USD) used when DEMO_MODE=true.
PAPER_BALANCE=1000

# ── Strategy ─────────────────────────────────────────────────────────────────
# Which trading format the bot runs (see docs/LADDER_STRATEGY.md for options).
TRADING_FORMAT=

# ── Telegram (this customer's own bot from BotFather) ────────────────────────
TELEGRAM_BOT_TOKEN=
# The customer's chat id. To also receive alerts yourself as the operator,
# see the "Operator oversight" section in CUSTOMER_ONBOARDING.md.
TELEGRAM_CHAT_ID=

# ── State file paths ─────────────────────────────────────────────────────────
# In a single-customer deploy these default to the attached Railway volume at
# /data, so persistence survives redeploys. Only override if you mount the
# volume somewhere else.
RECOVERY_STATE_PATH=/data/recovery_state.json
PROBATION_STATE_PATH=/data/probation_state.json
LADDER_STATE_PATH=/data/ladder_state.json
BUCKET_STATS_PATH=/data/bucket_stats.json
STATUS_SNAPSHOT_PATH=/data/status_snapshot.json
